<%- include("partials/header"); -%>
<%- include("partials/navbar"); -%>

<main>
  <div class="blog-section">
    <div class="container">
      <div class="blog-post">

        <div class="blog-post__meta">
          <div class="eyebrow">Latest update</div>
          <h1 class="blog-post__title"><%= title %></h1>
          <div class="blog-post__date"><%= date %></div>
        </div>

        <div class="blog-post__body">
          <% let photoIDX = 0; %>
          <% for (let i = 0; i < bodyArray.length; i++) { %>
            <% if (bodyArray[i].includes("^^^^^")) { %>
              <div class="blog-post__image">
                <img src="<%= photoURLs[photoIDX] %>" alt="Blog post photo" />
              </div>
              <% photoIDX += 1; %>
            <% } else { %>
              <p><%= bodyArray[i] %></p>
            <% } %>
          <% } %>
        </div>

        <div class="blog-post__back">
          <a class="btn btn-secondary" href="/">&#8592; Back to Home</a>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include("partials/footer"); -%>
