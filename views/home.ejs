<%- include("partials/header"); -%>
<%- include("partials/navbar"); -%>

<main>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__card">
        <div class="hero__content">
          <div class="eyebrow">Preventing childhood blindness</div>
          <h1>Every Child Deserves Clear Vision</h1>
          <p>Preventing childhood blindness through early detection, treatment, and access to care.</p>
          <div class="hero__buttons">
            <a class="btn btn-primary" href="/donate">Donate Now</a>
            <a class="btn btn-secondary" href="/about">Learn More</a>
          </div>
        </div>
        <div class="hero__media" role="img" aria-label="Group of providers at clinic in Puerto Peñasco"></div>
      </div>
    </div>
  </section>

  <!-- Impact Strip -->
  <section class="impact" id="impact">
    <div class="container">
      <div class="impact__grid">
        <div class="impact__item">
          <div class="impact__number">1.1 Billion</div>
          <div class="impact__label">Lack access to vision care</div>
        </div>
        <div class="impact__item">
          <div class="impact__number">19 Million</div>
          <div class="impact__label">Children visually impaired worldwide</div>
        </div>
        <div class="impact__item">
          <div class="impact__number">80%</div>
          <div class="impact__label">Of childhood vision loss is preventable</div>
        </div>
        <div class="impact__item">
          <div class="impact__number">One Pair of Glasses</div>
          <div class="impact__label"><span class="impact__highlight">= Life Changing</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why It Matters -->
  <section class="section problem">
    <div class="container">
      <div class="problem__grid">
        <div class="problem__copy">
          <div class="eyebrow">Why it matters</div>
          <h2>Children don't know their vision is <span class="accent">blurry</span></h2>
          <p>If a child has never seen clearly, they don't know anything is wrong.</p>
          <p>Without early screening, vision problems can permanently affect development, learning, and confidence.</p>
          <p>Little Eyes International brings monthly pediatric eye clinics, free prescription eyeglasses, and surgical care to children in Arizona and Mexico who would otherwise go without.</p>
        </div>
        <div class="vision-card">
          <div class="vision-card__split">
            <div class="vision-card__panel">
              <img src="images/ImageMiddleHome.jpeg" alt="Eye care at clinic" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section services" id="services">
    <div class="container">
      <div class="section-heading">
        <div class="eyebrow">What we do</div>
        <h2>Care that changes a child's future</h2>
        <p>We provide screenings, treatment, and access to surgical care so children can see clearly and thrive.</p>
      </div>
      <div class="services__grid">
        <article class="card">
          <div class="card__icon">&#128065;&#65039;</div>
          <h3>Vision Screenings</h3>
          <p>Early detection during critical developmental years helps identify vision problems before they become permanent.</p>
        </article>
        <article class="card">
          <div class="card__icon">&#128083;</div>
          <h3>Glasses &amp; Treatment</h3>
          <p>Complete eye exams, prescription glasses, and treatment for amblyopia, strabismus, and other childhood ocular conditions.</p>
        </article>
        <article class="card">
          <div class="card__icon">&#127973;</div>
          <h3>Surgical Care</h3>
          <p>Strabismus repair, nasolacrimal duct obstruction, congenital ptosis, and other sight-saving procedures for children who need them.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta__card">
        <div class="cta__media">
          <img src="images/ImageBottomHome.jpg" alt="Eye care providers at clinic" />
        </div>
        <div class="cta__content">
          <div class="eyebrow">Get involved</div>
          <h2>Help a Child See Clearly</h2>
          <p>Your support brings vision care to children who need it most. Every donation helps provide screenings, glasses, treatment, and access to life-changing care. Our current efforts are focused in Arizona and Mexico.</p>
          <div class="cta__buttons">
            <a class="btn btn-primary" href="/donate">Donate Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include("partials/footer"); -%>
